{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(terraform validate*)",
      "Bash(terraform plan*)",
      "Bash(terraform fmt*)",
      "Bash(terraform providers*)",
      "Bash(terraform version*)",
      "Bash(terraform state list*)",
      "Bash(terraform state show*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl top*)",
      "Bash(kubectl auth can-i*)",
      "Bash(kubectl config view*)",
      "Bash(helm list*)",
      "Bash(helm status*)",
      "Bash(helm get*)",
      "Bash(helm template*)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git worktree*)",
      "Bash(gh search*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr create*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue*)",
      "Bash(gh repo view*)",
      "Bash(gh api*)",
      "Bash(gh auth token)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh pr review:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push origin HEAD:master:*)",
      "Bash(git push * main:*)",
      "Bash(git push * master:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform import:*)",
      "Bash(terraform state rm:*)",
      "Bash(terraform state mv:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl create:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl edit:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl replace:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl rollout undo:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(helm rollback:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-push-to-main.sh\"",
            "statusMessage": "Checking push target..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "statusMessage": "Checking the change resolves the findings...",
            "prompt": "Completion gate. If the conversation surfaced code/infra findings to fix, allow stopping ONLY when each is shown RESOLVED with evidence (build exits 0, error gone, UAT passes); else decision:block naming the unresolved finding(s). No findings: allow. Loop guard: if a finding stalled 3+ turns or needs a human/manual gate, allow and state what remains. Input: $ARGUMENTS"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "statusMessage": "Checking subagent met its goal...",
            "prompt": "Gate ONLY issue-researcher, app/iac-troubleshooter, uat-tester (else accept). Read-only finders (issue-researcher, iac-troubleshooter): accept only if each issue is a checkable finding (symptom, root cause, 'resolved when', how to verify) — else decision:block. app-troubleshooter: accept only if its fix made the original error stop reproducing — else block. uat-tester: accept PASS only if every inherited finding is verified resolved — else block and name it. When unsure, accept. Input: $ARGUMENTS"
          }
        ]
      }
    ]
  }
}
