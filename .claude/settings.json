{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(terraform validate*)",
      "Bash(terraform plan*)",
      "Bash(terraform fmt*)",
      "Bash(terraform providers*)",
      "Bash(terraform version*)",
      "Bash(terraform state list*)",
      "Bash(terraform state show*)",
      "Bash(kubectl get*)",
      "Bash(kubectl describe*)",
      "Bash(kubectl logs*)",
      "Bash(kubectl top*)",
      "Bash(kubectl auth can-i*)",
      "Bash(kubectl config view*)",
      "Bash(helm list*)",
      "Bash(helm status*)",
      "Bash(helm get*)",
      "Bash(helm template*)",
      "Bash(go *)",
      "Bash(gofmt *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(yarn *)",
      "Bash(pnpm *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git worktree*)",
      "Bash(gh search*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr create*)",
      "Bash(gh pr diff*)",
      "Bash(gh issue*)",
      "Bash(gh repo view*)",
      "Bash(gh api*)",
      "Bash(gh auth token)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh pr review:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push origin main:*)",
      "Bash(git push origin master:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push origin HEAD:master:*)",
      "Bash(git push * main:*)",
      "Bash(git push * master:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(terraform import:*)",
      "Bash(terraform state rm:*)",
      "Bash(terraform state mv:*)",
      "Bash(terraform force-unlock:*)",
      "Bash(kubectl apply:*)",
      "Bash(kubectl create:*)",
      "Bash(kubectl delete:*)",
      "Bash(kubectl edit:*)",
      "Bash(kubectl patch:*)",
      "Bash(kubectl replace:*)",
      "Bash(kubectl scale:*)",
      "Bash(kubectl drain:*)",
      "Bash(kubectl cordon:*)",
      "Bash(kubectl rollout undo:*)",
      "Bash(helm install:*)",
      "Bash(helm upgrade:*)",
      "Bash(helm uninstall:*)",
      "Bash(helm rollback:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block-push-to-main.sh\"",
            "statusMessage": "Checking push target..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "statusMessage": "Checking the change resolves the findings...",
            "prompt": "Completion gate. If the conversation surfaced concrete code/infra issues or errors meant to be fixed (e.g. issue-researcher, app-troubleshooter, iac-troubleshooter, or uat-tester ran), the task is done ONLY when it shows the change actually RESOLVED each one with evidence (build exits 0, error no longer reproduces, UAT criteria hold). A diagnosis, an unapplied fix, or an unrelated green test is not enough — return decision:block and name the unresolved finding(s) in reason. If no such findings exist, allow the stop. Loop guard: if a finding has stalled across 3+ turns or needs a human/manual gate, allow the stop and state what remains. Input: $ARGUMENTS"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "statusMessage": "Checking subagent met its goal...",
            "prompt": "Accept a finished subagent only if it met its goal; gate ONLY issue-researcher, app-troubleshooter, iac-troubleshooter, uat-tester (else accept). issue-researcher / iac-troubleshooter (read-only): each issue must be a checkable finding (symptom, root cause, observable 'resolved when', how to verify) — else decision:block to make them checkable. app-troubleshooter: must show its fix made the original error stop reproducing — else block. uat-tester: PASS only if every inherited finding is verified resolved — else block and name it. When unsure, accept. Input: $ARGUMENTS"
          }
        ]
      }
    ]
  }
}
